{
  "name": "feedformula-ai",
  "version": "1.0.0",
  "description": "L'écosystème IA agricole le plus complet jamais créé pour l'Afrique",
  "author": "Leonel TOGBE <leonel.togbe@feedformula.ai>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "frontend": "cd frontend && npm start",
    "backend": "cd backend && uvicorn main:app --reload --port 8000",
    "build": "node -e \"process.stdout.write('Static frontend handled by vercel.json\\n')\"",
    "test": "python -m pytest tests/test_api.py tests/test_ci_strict.py tests/test_frontend_polish.py -q",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:quality": "npm run test && npm run test:e2e"
  },
  "keywords": [
    "agriculture",
    "IA",
    "Afrique",
    "élevage",
    "nutrition animale",
    "multilingue",
    "fon",
    "yoruba"
  ],
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  }
}
