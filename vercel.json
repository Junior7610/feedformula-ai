{
  "version": 2,
  "name": "feedformula-ai",
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/app/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/main.py"
    }
  ],
  "env": {
    "AFRI_API_KEY": "@afri_api_key",
    "AFRI_BASE_URL": "@afri_base_url",
    "MODEL_LLM": "gpt-5.5",
    "MODEL_CODEX": "gpt-5.3-codex"
  }
}
